// 复制这个文件为 Secrets.xcconfig（同目录下），并填入真实的 key。
// Secrets.xcconfig 已经在 .gitignore 里，不会被提交到仓库。
TRIPO_API_KEY = your_api_key_here
// Mapbox 公开 token（pk. 开头），account.mapbox.com/access-tokens 直接复制默认那个。
// 会被塞进 Info.plist 的 MBXAccessToken，SDK 启动时读它。
// 注意：另有一个 sk. 下载 token 是 CI 拉 SDK 用的，那个存 GitHub Secrets，不放这里。
// CI 上这两个都从仓库 Secrets 取：MAPBOX_PUBLIC_TOKEN + MAPBOX_DOWNLOAD_TOKEN。
MAPBOX_PUBLIC_TOKEN = pk.your_public_token_here
